# Block direct push to main/master
sh .husky/scripts/no-direct-push-main-master.sh

# Check for conflicts with main before pushing
sh .husky/scripts/check-conflicts-with-main.sh

# Signal to reference-transaction hook that this is a push operation
# (vs git pull/fetch which also updates tracking refs)
mkdir -p .husky/_
touch .husky/_/.push-in-progress
